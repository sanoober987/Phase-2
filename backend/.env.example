# Database connection (Neon Serverless PostgreSQL)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require

# JWT Authentication
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
# Must match BETTER_AUTH_SECRET on the frontend.
JWT_SECRET_KEY=

# Optional JWT settings
JWT_ALGORITHM=HS256
JWT_EXPIRES_IN=3600
ENVIRONMENT=development
LOG_LEVEL=INFO

# CORS
CORS_ORIGINS=http://localhost:3000

# ── Groq API ──────────────────────────────────────────────────────────────────
# Get your key from https://console.groq.com/keys
GROQ_API_KEY=gsk-your-key-here

# Groq API base URL (OpenAI-compatible endpoint)
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Model (default: llama-3.1-8b-instant — fast, free tier available)
# Options: llama-3.1-8b-instant, llama-3.3-70b-versatile, mixtral-8x7b-32768, gemma2-9b-it
GROQ_MODEL=llama-3.1-8b-instant

# Request timeout in seconds
GROQ_TIMEOUT=60

# Max tokens for the AI response (output)
GROQ_MAX_TOKENS=2048

# Max estimated input tokens before history trimming kicks in
GROQ_MAX_INPUT_TOKENS=8000

# Retry attempts for rate-limit (429) and server errors (5xx)
GROQ_MAX_RETRIES=3

# Per-user request limit (requests per minute per user)
GROQ_USER_RPM=20

# Number of previous messages to load as context
CHAT_HISTORY_DEPTH=20
